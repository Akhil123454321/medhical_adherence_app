# Copy this file to .env.local and fill in the values before deploying.
# Never commit .env.local to git.

# -----------------------------------------------------------------------
# Auth (REQUIRED)
# Generate with:  openssl rand -hex 32
# -----------------------------------------------------------------------
AUTH_SECRET=

# -----------------------------------------------------------------------
# SendGrid email (REQUIRED for verification emails)
# -----------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=medhadherehelp@gmail.com

# -----------------------------------------------------------------------
# Cap upload API key (REQUIRED — give this to Kyle)
# Generate with:  openssl rand -hex 24
# -----------------------------------------------------------------------
CAP_UPLOAD_API_KEY=

# -----------------------------------------------------------------------
# Public base URL  (no trailing slash)
# -----------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://YOUR_DOMAIN.com
